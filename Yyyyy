<script>
// ===== IndexedDB =====
let db;
const DB_NAME = 'OmborDB', DB_VER = 1;

function openDB() {
  return new Promise((res, rej) => {
    const req = indexedDB.open(DB_NAME, DB_VER);
    req.onupgradeneeded = e => {
      const d = e.target.result;
      if (!d.objectStoreNames.contains('products')) {
        const ps = d.createObjectStore('products', { keyPath: 'id' });
        ps.createIndex('date', 'date');
      }
      if (!d.objectStoreNames.contains('sales')) {
        d.createObjectStore('sales', { keyPath: 'id' });
      }
    };
    req.onsuccess = e => { db = e.target.result; res(db); };
    req.onerror = () => rej(req.error);
  });
}

function dbGetAll(store) {
  return new Promise((res, rej) => {
    const tx = db.transaction(store, 'readonly');
    const req = tx.objectStore(store).getAll();
    req.onsuccess = () => res(req.result);
    req.onerror = () => rej(req.error);
  });
}

function dbPut(store, obj) {
  return new Promise((res, rej) => {
    const tx = db.transaction(store, 'readwrite');
    const req = tx.objectStore(store).put(obj);
    req.onsuccess = () => res();
    req.onerror = () => rej(req.error);
  });
}

function dbDelete(store, id) {
  return new Promise((res, rej) => {
    const tx = db.transaction(store, 'readwrite');
    const req = tx.objectStore(store).delete(id);
    req.onsuccess = () => res();
    req.onerror = () => rej(req.error);
  });
}

// ===== STATE =====
let products = [], sales = [];
let editId = null, sellId = null;
let currentImage = null, sellImage = null;
let stream = null, sStream = null;

function openViewer(src) {
  document.getElementById('viewerImg').src = src;
  document.getElementById('imgViewer').style.display = 'flex';
}
function closeViewer() {
  document.getElementById('imgViewer').style.display = 'none';
}

function fmt(n) { return Number(n||0).toLocaleString('uz-UZ'); }
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

function showToast(msg, err) {
  const t = document.createElement('div');
  t.className = 'toast' + (err ? ' err' : '');
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 2500);
}

async function loadAll() {
  products = await dbGetAll('products');
  products.sort((a, b) => b.id - a.id);
  sales = await dbGetAll('sales');
  sales.sort((a, b) => b.id - a.id);
}

// ===== TABS =====
function switchTab(tab, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + tab).classList.add('active');
  document.getElementById('fabBtn').style.display = tab === 'ombor' ? 'flex' : 'none';
  if (tab === 'sotilgan') renderSotilgan();
  if (tab === 'tugagan') renderTugagan();
  if (tab === 'hisobot') renderHisobot();
}

// ===== OMBOR =====
function renderOmbor() {
  const q = document.getElementById('searchInput').value.toLowerCase();
  const filtered = products.filter(p => p.qty > 0 && p.name.toLowerCase().includes(q));
  const totalDona = products.reduce((s, p) => s + p.qty, 0);
  const mavjud = products.filter(p => p.qty > 0).length;
  const tugagan = products.filter(p => p.qty === 0).length;
  const mavjudSumma = products.filter(p => p.qty > 0).reduce((s, p) => s + p.qty * (p.sellPrice || 0), 0);

  document.getElementById('totalTypes').textContent = products.length;
  document.getElementById('omborStats').innerHTML = `
    <div class="stat stat-gold"><div class="stat-num">${totalDona}</div><div class="stat-lbl">Jami dona</div></div>
    <div class="stat stat-green"><div class="stat-num">${mavjud}</div><div class="stat-lbl">Mavjud tur</div></div>
    <div class="stat stat-red"><div class="stat-num">${tugagan}</div><div class="stat-lbl">Tugagan</div></div>`;

  document.getElementById('sumCard').innerHTML = mavjudSumma > 0
    ? `<div style="display:flex;justify-content:space-between;align-items:center">
        <div>
          <div style="font-size:10px;color:var(--muted);margin-bottom:3px">MAVJUD TOVARLAR SUMMASI</div>
          <div style="font-size:22px;font-weight:900;color:var(--green)">${fmt(mavjudSumma)} so'm</div>
          <div style="font-size:10px;color:var(--muted);margin-top:2px">sotish narxi bo'yicha</div>
        </div>
        <div style="font-size:34px">💰</div>
      </div>`
    : `<div style="font-size:12px;color:var(--muted);text-align:center;padding:2px 0">Sotish narxlarini kiriting — summa ko'rinadi</div>`;

  const list = document.getElementById('omborList');
  if (filtered.length === 0) {
    list.innerHTML = `<div class="empty"><div class="empty-ico">📦</div><div class="empty-ttl">${q ? 'Topilmadi' : "Mahsulot yo'q"}</div><div class="empty-sub">+ tugmani bosing</div></div>`;
    return;
  }
  list.innerHTML = filtered.map(p => {
    const qc = p.qty === 0 ? '#ef4444' : p.qty < 5 ? '#f59e0b' : '#22c55e';
    const soldQty = sales.filter(s => s.productId === p.id).reduce((a, s) => a + s.qty, 0);
    return `<div class="card">
      <div class="card-img" ${p.image ? `onclick="openViewer('${p.image}')"` : ''}>${p.image ? `<img src="${p.image}" alt="">` : '📦'}</div>
      <div class="card-info">
        <div class="card-name">${esc(p.name)}</div>
        ${p.sellPrice ? `<span class="price-tag">💵 ${fmt(p.sellPrice)} so'm</span>` : ''}
        <div class="card-date">${p.date}</div>
        <div class="qty-row">
          <span class="qty-val" style="color:${qc};font-size:15px;font-weight:800">${p.qty}</span>
          <span class="qty-unit">dona qoldi</span>
        </div>
        ${soldQty > 0 ? `<div class="sold-badge">✅ ${soldQty} dona sotilgan</div>` : ''}
      </div>
      <div class="card-actions">
        <button class="act-btn act-sell" onclick="openSell(${p.id})">💰</button>
        <button class="act-btn act-edit" onclick="openEdit(${p.id})">✏️</button>
        <button class="act-btn act-del" onclick="delProduct(${p.id})">🗑️</button>
      </div>
    </div>`;
  }).join('');
}

async function changeQty(id, d) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  p.qty = Math.max(0, p.qty + d);
  await dbPut('products', p);
  renderOmbor();
}

async function delProduct(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  if (!confirm(`"${p.name}" o'chirilsinmi?`)) return;
  if (!confirm(`Ishonchingiz komilmi? "${p.name}" butunlay o'chib ketadi!`)) return;
  products = products.filter(p => p.id !== id);
  await dbDelete('products', id);
  renderOmbor();
  showToast("O'chirildi 🗑️");
}

// ===== QO'SHISH / TAHRIRLASH =====
function openAdd() {
  editId = null; currentImage = null;
  document.getElementById('fName').value = '';
  document.getElementById('fQty').value = 1;
  document.getElementById('fSellPrice').value = '';
  document.getElementById('previewImg').src = '';
  document.getElementById('imgPreview').style.display = 'none';
  document.getElementById('modalTitle').textContent = '➕ Yangi mahsulot';
  document.getElementById('saveBtn').textContent = "✅ Qo'shish";
  document.getElementById('modal').style.display = 'flex';
  stopCamera();
}

function openEdit(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  editId = id; currentImage = p.image || null;
  document.getElementById('fName').value = p.name;
  document.getElementById('fQty').value = p.qty;
  document.getElementById('fSellPrice').value = p.sellPrice || '';
  if (p.image) { document.getElementById('previewImg').src = p.image; document.getElementById('imgPreview').style.display = 'block'; }
  else document.getElementById('imgPreview').style.display = 'none';
  document.getElementById('modalTitle').textContent = '✏️ Tahrirlash';
  document.getElementById('saveBtn').textContent = '💾 Saqlash';
  document.getElementById('modal').style.display = 'flex';
  stopCamera();
}

function closeModal() { stopCamera(); document.getElementById('modal').style.display = 'none'; }

async function saveProduct() {
  const name = document.getElementById('fName').value.trim();
  const qty = parseInt(document.getElementById('fQty').value) || 0;
  const sellPrice = parseFloat(document.getElementById('fSellPrice').value) || 0;
  if (!name) { showToast('Nom kiriting!', true); return; }
  if (editId !== null) {
    const p = products.find(x => x.id === editId);
    if (p) { p.name = name; p.qty = qty; p.sellPrice = sellPrice; p.image = currentImage; }
    await dbPut('products', p);
    showToast('Yangilandi ✓');
  } else {
    const p = { id: Date.now(), name, qty, sellPrice, image: currentImage, date: new Date().toLocaleDateString('uz-UZ') };
    products.unshift(p);
    await dbPut('products', p);
    showToast("Qo'shildi ✓");
  }
  closeModal(); renderOmbor();
}

// ===== SOTISH =====
function openSell(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  if (p.qty === 0) { showToast("Omborda mahsulot yo'q!", true); return; }
  sellId = id; sellImage = null;
  document.getElementById('sellProdName').textContent = '📦 ' + p.name;
  document.getElementById('sellProdStock').textContent = `Qoldiq: ${p.qty} dona`;
  document.getElementById('sQty').value = 1;
  document.getElementById('sSellPrice').value = p.sellPrice || '';
  document.getElementById('sPreviewImg').src = '';
  document.getElementById('sImgPreview').style.display = 'none';
  document.getElementById('sCamWrap').style.display = 'none';
  document.getElementById('sImgBtns').style.display = 'flex';
  updateSellTotal();
  document.getElementById('sellModal').style.display = 'flex';
  document.getElementById('sQty').oninput = updateSellTotal;
  document.getElementById('sSellPrice').oninput = updateSellTotal;
}

function updateSellTotal() {
  const qty = parseInt(document.getElementById('sQty').value) || 0;
  const price = parseFloat(document.getElementById('sSellPrice').value) || 0;
  const total = qty * price;
  document.getElementById('sellTotal').textContent = total > 0 ? `Jami: ${fmt(total)} so'm` : "Narx kiriting — jami ko'rinadi";
}

function closeSellModal() { sStopCamera(); document.getElementById('sellModal').style.display = 'none'; }

async function confirmSell() {
  const p = products.find(x => x.id === sellId);
  if (!p) return;
  const qty = parseInt(document.getElementById('sQty').value) || 0;
  const sellPrice = parseFloat(document.getElementById('sSellPrice').value) || 0;
  if (qty <= 0) { showToast("Miqdor kiriting!", true); return; }
  if (qty > p.qty) { showToast(`Faqat ${p.qty} dona bor!`, true); return; }
  p.qty -= qty;
  await dbPut('products', p);
  const totalSum = sellPrice * qty;
  const sale = {
    id: Date.now(), productId: p.id, productName: p.name,
    productImage: p.image, saleImage: sellImage,
    qty, sellPrice, totalSum,
    date: new Date().toLocaleDateString('uz-UZ'),
    time: new Date().toLocaleTimeString('uz-UZ', { hour: '2-digit', minute: '2-digit' })
  };
  sales.unshift(sale);
  await dbPut('sales', sale);
  closeSellModal(); renderOmbor();
  showToast(`✅ ${qty} dona sotildi! Jami: ${fmt(totalSum)} so'm`);
}

// ===== SOTILGAN =====
function renderSotilgan() {
  const totalSum = sales.reduce((s, x) => s + x.totalSum, 0);
  const totalQty = sales.reduce((s, x) => s + x.qty, 0);
  document.getElementById('soldCount').textContent = sales.length;
  document.getElementById('soldTotalSum').textContent = fmt(totalSum) + " so'm";
  document.getElementById('soldTotalQty').textContent = totalQty + " dona sotilgan";
  const list = document.getElementById('sotilganList');
  if (sales.length === 0) {
    list.innerHTML = `<div class="empty"><div class="empty-ico">🛒</div><div class="empty-ttl">Hali sotilmagan</div><div class="empty-sub">Ombordan 💰 tugma orqali soting</div></div>`;
    return;
  }
  list.innerHTML = sales.map(s => `
    <div class="sold-card">
      <div class="sold-img">${s.saleImage ? `<img src="${s.saleImage}" alt="">` : s.productImage ? `<img src="${s.productImage}" alt="">` : '📦'}</div>
      <div class="sold-body">
        <div class="sold-name">${esc(s.productName)}</div>
        <div class="sold-row"><span class="sold-lbl">Sotilgan dona:</span><span class="sold-val" style="color:var(--gold)">${s.qty} dona</span></div>
        <div class="sold-row"><span class="sold-lbl">Narxi:</span><span class="sold-val">${fmt(s.sellPrice)} so'm/dona</span></div>
        <div class="sold-row"><span class="sold-lbl">Jami summa:</span><span class="sold-val" style="color:var(--green)">${fmt(s.totalSum)} so'm</span></div>
        <div class="sold-row"><span class="sold-lbl" style="color:var(--muted)">${s.date} ${s.time || ''}</span><span></span></div>
      </div>
      <button class="act-btn act-del" onclick="delSale(${s.id})" style="flex-shrink:0;align-self:center">🗑️</button>
    </div>`).join('');
}

// ===== TUGAGAN =====
function renderTugagan() {
  const tugagan = products.filter(p => p.qty === 0);
  document.getElementById('tugaganCount').textContent = tugagan.length;
  const list = document.getElementById('tugaganList');
  if (tugagan.length === 0) {
    list.innerHTML = `<div class="empty"><div class="empty-ico">✅</div><div class="empty-ttl">Tugagan mahsulot yo'q</div><div class="empty-sub">Barcha tovarlar mavjud!</div></div>`;
    return;
  }
  list.innerHTML = tugagan.map(p => `
    <div class="card" style="border-color:rgba(239,68,68,0.3)">
      <div class="card-img" ${p.image ? `onclick="openViewer('${p.image}')"` : ''}>${p.image ? `<img src="${p.image}" alt="">` : '📦'}</div>
      <div class="card-info">
        <div class="card-name">${esc(p.name)}</div>
        ${p.sellPrice ? `<span class="price-tag">💵 ${fmt(p.sellPrice)} so'm</span>` : ''}
        <div class="card-date">${p.date}</div>
        <div style="font-size:12px;color:var(--red);font-weight:700;margin-top:4px">❌ Tugagan</div>
      </div>
      <div class="card-actions">
        <button class="act-btn act-edit" onclick="openEdit(${p.id})">✏️</button>
        <button class="act-btn act-del" onclick="delProduct(${p.id})">🗑️</button>
      </div>
    </div>`).join('');
}

async function delSale(id) {
  if (!confirm("Bu yozuv o'chirilsinmi?")) return;
  sales = sales.filter(s => s.id !== id);
  await dbDelete('sales', id);
  renderSotilgan();
  showToast("O'chirildi 🗑️");
}

// ===== HISOBOT =====
function renderHisobot() {
  const totalSoldSum = sales.reduce((s, x) => s + x.totalSum, 0);
  const totalSoldQty = sales.reduce((s, x) => s + x.qty, 0);
  const mavjudSumma = products.filter(p => p.qty > 0).reduce((s, p) => s + p.qty * (p.sellPrice || 0), 0);
  const totalDona = products.reduce((s, p) => s + p.qty, 0);
  document.getElementById('hisobotContent').innerHTML = `
    <div class="big-sum">
      <div class="big-sum-lbl">Jami sotuv summasi</div>
      <div class="big-sum-num">${fmt(totalSoldSum)} so'm</div>
    </div>
    <div class="report-title">Savdo hisoboti</div>
    <div class="report-card">
      <div class="report-row"><span class="report-lbl">Jami sotilgan dona</span><span class="report-val" style="color:var(--green)">${totalSoldQty} dona</span></div>
      <div class="report-row"><span class="report-lbl">Jami sotuv summasi</span><span class="report-val" style="color:var(--green)">${fmt(totalSoldSum)} so'm</span></div>
      <div class="report-row"><span class="report-lbl">Sotuv yozuvlari</span><span class="report-val">${sales.length} ta</span></div>
    </div>
    <div class="report-title">Ombor holati</div>
    <div class="report-card">
      <div class="report-row"><span class="report-lbl">Mahsulot turlari</span><span class="report-val">${products.length} ta</span></div>
      <div class="report-row"><span class="report-lbl">Jami qoldiq</span><span class="report-val">${totalDona} dona</span></div>
      <div class="report-row"><span class="report-lbl">Mavjud tovarlar summasi</span><span class="report-val" style="color:var(--gold)">${fmt(mavjudSumma)} so'm</span></div>
      <div class="report-row"><span class="report-lbl">Tugagan mahsulotlar</span><span class="report-val" style="color:var(--red)">${products.filter(p=>p.qty===0).length} ta</span></div>
    </div>
    ${sales.length > 0 ? `
    <div class="report-title">Mahsulot bo'yicha sotuv</div>
    <div class="report-card">
      ${[...new Set(sales.map(s=>s.productId))].map(pid=>{
        const ps=sales.filter(s=>s.productId===pid);
        const pSum=ps.reduce((a,s)=>a+s.totalSum,0);
        const pQty=ps.reduce((a,s)=>a+s.qty,0);
        return `<div class="report-row"><span class="report-lbl">${esc(ps[0].productName)} — ${pQty} dona</span><span class="report-val" style="color:var(--green)">${fmt(pSum)} so'm</span></div>`;
      }).join('')}
    </div>` : ''}`;
}

// ===== KAMERA =====
async function startCamera() {
  document.getElementById('camWrap').style.display='block';
  document.getElementById('imgBtns').style.display='none';
  document.getElementById('imgPreview').style.display='none';
  try { stream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'}}); document.getElementById('video').srcObject=stream; }
  catch { showToast("Kamera ishlamadi",true); stopCamera(); }
}
function stopCamera() {
  if(stream){stream.getTracks().forEach(t=>t.stop());stream=null;}
  document.getElementById('camWrap').style.display='none';
  document.getElementById('imgBtns').style.display='flex';
}
function capturePhoto() {
  const v=document.getElementById('video');
  const c=document.createElement('canvas');
  c.width=v.videoWidth; c.height=v.videoHeight;
  c.getContext('2d').drawImage(v,0,0);
  currentImage=c.toDataURL('image/jpeg',0.85);
  document.getElementById('previewImg').src=currentImage;
  document.getElementById('imgPreview').style.display='block';
  stopCamera();
}
function handleFile(e) {
  const file=e.target.files[0]; if(!file)return;
  const r=new FileReader();
  r.onload=ev=>{currentImage=ev.target.result; document.getElementById('previewImg').src=currentImage; document.getElementById('imgPreview').style.display='block';};
  r.readAsDataURL(file); e.target.value='';
}

// ===== SOTISH KAMERA =====
async function sStartCamera() {
  document.getElementById('sCamWrap').style.display='block';
  document.getElementById('sImgBtns').style.display='none';
  document.getElementById('sImgPreview').style.display='none';
  try { sStream=await navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'}}); document.getElementById('sVideo').srcObject=sStream; }
  catch { showToast("Kamera ishlamadi",true); sStopCamera(); }
}
function sStopCamera() {
  if(sStream){sStream.getTracks().forEach(t=>t.stop());sStream=null;}
  document.getElementById('sCamWrap').style.display='none';
  document.getElementById('sImgBtns').style.display='flex';
}
function sCapturePhoto() {
  const v=document.getElementById('sVideo');
  const c=document.createElement('canvas');
  c.width=v.videoWidth; c.height=v.videoHeight;
  c.getContext('2d').drawImage(v,0,0);
  sellImage=c.toDataURL('image/jpeg',0.85);
  document.getElementById('sPreviewImg').src=sellImage;
  document.getElementById('sImgPreview').style.display='block';
  sStopCamera();
}
function sSellHandleFile(e) {
  const file=e.target.files[0]; if(!file)return;
  const r=new FileReader();
  r.onload=ev=>{sellImage=ev.target.result; document.getElementById('sPreviewImg').src=sellImage; document.getElementById('sImgPreview').style.display='block';};
  r.readAsDataURL(file); e.target.value='';
}

// ===== START =====
openDB().then(async () => {
  await loadAll();
  renderOmbor();
}).catch(() => {
  showToast("Xatolik yuz berdi", true);
});
</script>
