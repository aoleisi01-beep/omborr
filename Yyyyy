<!DOCTYPE html>
<html lang="uz">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#0f0f13">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Ombor">
<title>Mening Omborim</title>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{--bg:#0f0f13;--border:rgba(255,255,255,0.08);--gold:#f59e0b;--red:#ef4444;--green:#22c55e;--blue:#3b82f6;--purple:#818cf8;--text:#f0ede8;--muted:#6b7280}
body{background:var(--bg);color:var(--text);font-family:'Segoe UI',sans-serif;min-height:100vh}

.tabs{display:flex;background:#13131f;border-bottom:1px solid var(--border);position:sticky;top:0;z-index:50}
.tab{flex:1;padding:13px 3px;text-align:center;font-size:10px;font-weight:700;color:var(--muted);border:none;background:none;cursor:pointer;border-bottom:2px solid transparent;letter-spacing:.3px}
.tab.active{color:var(--gold);border-bottom-color:var(--gold)}
.page{display:none;padding-bottom:90px}
.page.active{display:block}

.hcard{background:linear-gradient(135deg,#1a1a2e,#16213e);padding:14px}
.hcard-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.brand{font-size:20px;font-weight:900;background:linear-gradient(90deg,#f59e0b,#ef4444);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.search-wrap{position:relative}
.search-ico{position:absolute;left:11px;top:50%;transform:translateY(-50%);font-size:13px}
.search-input{width:100%;background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:9px;padding:10px 11px 10px 33px;color:var(--text);font-size:13px;outline:none}

.stats{display:flex;gap:7px;padding:12px 12px 0}
.stat{flex:1;border-radius:10px;padding:9px 8px;text-align:center}
.stat-gold{background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.2)}
.stat-red{background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.2)}
.stat-green{background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.2)}
.stat-num{font-size:15px;font-weight:800}
.stat-gold .stat-num{color:var(--gold)}
.stat-red .stat-num{color:var(--red)}
.stat-green .stat-num{color:var(--green)}
.stat-lbl{font-size:9px;color:#9ca3af;margin-top:2px}

.sum-card{margin:10px 12px 0;background:linear-gradient(135deg,rgba(34,197,94,0.12),rgba(34,197,94,0.06));border:1px solid rgba(34,197,94,0.25);border-radius:12px;padding:12px 14px}

.list{padding:10px 12px;display:flex;flex-direction:column;gap:10px}
.empty{text-align:center;padding:50px 20px;color:var(--muted)}
.empty-ico{font-size:42px;margin-bottom:10px}
.empty-ttl{font-size:14px;font-weight:600}
.empty-sub{font-size:12px;margin-top:5px}

.card{background:linear-gradient(135deg,#1c1c2e,#1a1a2a);border:1px solid var(--border);border-radius:14px;padding:11px;display:flex;gap:11px;align-items:flex-start}
.card-img{width:62px;height:62px;border-radius:10px;overflow:hidden;flex-shrink:0;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;font-size:22px;cursor:pointer}
.card-img img{width:100%;height:100%;object-fit:cover}
.img-viewer{position:fixed;inset:0;background:rgba(0,0,0,0.95);z-index:999;display:flex;align-items:center;justify-content:center}
.img-viewer img{max-width:100%;max-height:100%;object-fit:contain;border-radius:8px}
.img-viewer-close{position:absolute;top:16px;right:16px;width:40px;height:40px;background:rgba(255,255,255,0.15);border:none;color:#fff;font-size:22px;border-radius:50%;cursor:pointer}
.card-info{flex:1;min-width:0}
.card-name{font-weight:700;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:3px}
.price-tag{font-size:11px;padding:2px 8px;border-radius:5px;font-weight:600;display:inline-block;margin-bottom:4px;background:rgba(34,197,94,0.15);color:#4ade80}
.card-date{font-size:10px;color:var(--muted);margin-bottom:5px}
.qty-row{display:flex;align-items:center;gap:6px}
.qty-btn{width:26px;height:26px;border-radius:6px;border:none;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;font-weight:700}
.qty-minus{background:rgba(239,68,68,0.12);color:var(--red);border:1px solid rgba(239,68,68,0.3)}
.qty-plus{background:rgba(34,197,94,0.12);color:var(--green);border:1px solid rgba(34,197,94,0.3)}
.qty-val{min-width:28px;text-align:center;font-weight:800;font-size:14px}
.qty-unit{font-size:10px;color:var(--muted)}
.sold-badge{font-size:10px;color:var(--blue);margin-top:3px}
.card-actions{display:flex;flex-direction:column;gap:6px;flex-shrink:0}
.act-btn{width:32px;height:32px;border-radius:8px;border:none;cursor:pointer;font-size:14px}
.act-sell{background:rgba(34,197,94,0.12);border:1px solid rgba(34,197,94,0.3)}
.act-edit{background:rgba(99,102,241,0.12);border:1px solid rgba(99,102,241,0.3)}
.act-del{background:rgba(239,68,68,0.08);border:1px solid rgba(239,68,68,0.25)}

.sold-card{background:linear-gradient(135deg,#1c1c2e,#1a1a2a);border:1px solid var(--border);border-radius:14px;padding:12px;display:flex;gap:11px;align-items:center}
.sold-img{width:52px;height:52px;border-radius:9px;overflow:hidden;flex-shrink:0;background:rgba(255,255,255,0.05);display:flex;align-items:center;justify-content:center;font-size:20px}
.sold-img img{width:100%;height:100%;object-fit:cover}
.sold-body{flex:1;min-width:0}
.sold-name{font-weight:700;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:5px}
.sold-row{display:flex;justify-content:space-between;font-size:11px;padding:2px 0}
.sold-lbl{color:var(--muted)}
.sold-val{font-weight:700}

.report-section{padding:12px}
.report-title{font-size:11px;color:var(--muted);letter-spacing:1px;margin-bottom:8px;text-transform:uppercase}
.report-card{background:linear-gradient(135deg,#1c1c2e,#1a1a2a);border:1px solid var(--border);border-radius:14px;padding:14px;margin-bottom:10px}
.report-row{display:flex;justify-content:space-between;align-items:center;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.04)}
.report-row:last-child{border-bottom:none}
.report-lbl{font-size:12px;color:var(--muted)}
.report-val{font-size:13px;font-weight:800}
.big-sum{text-align:center;padding:18px;border-radius:14px;margin-bottom:10px;background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3)}
.big-sum-lbl{font-size:11px;color:var(--muted);margin-bottom:5px}
.big-sum-num{font-size:26px;font-weight:900;color:var(--green)}

.fab{position:fixed;bottom:24px;right:20px;width:56px;height:56px;border-radius:16px;background:linear-gradient(135deg,#f59e0b,#ef4444);border:none;color:#fff;font-size:26px;cursor:pointer;box-shadow:0 8px 26px rgba(245,158,11,0.45);z-index:100;display:flex;align-items:center;justify-content:center}

.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.88);z-index:200;display:flex;flex-direction:column;justify-content:flex-end}
.modal{background:#13131f;border-radius:20px 20px 0 0;padding:20px 16px 32px;max-height:92vh;overflow-y:auto}
.modal-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}
.modal-title{font-size:16px;font-weight:800}
.close-btn{background:rgba(255,255,255,0.08);border:none;color:#9ca3af;width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:16px}
video{width:100%;display:block;border-radius:12px}
.cam-btns{display:flex;gap:9px;margin-top:8px;margin-bottom:10px}
.img-preview{border-radius:12px;overflow:hidden;height:130px;margin-bottom:9px}
.img-preview img{width:100%;height:100%;object-fit:cover}
.img-btns{display:flex;gap:9px;margin-bottom:12px}
.img-btn{flex:1;padding:10px;border-radius:10px;border:none;font-weight:600;font-size:12px;cursor:pointer}
.img-btn-cam{background:rgba(245,158,11,0.15);border:1px solid rgba(245,158,11,0.3);color:var(--gold)}
.img-btn-gal{background:rgba(99,102,241,0.15);border:1px solid rgba(99,102,241,0.3);color:var(--purple)}
.field{margin-bottom:10px}
.field label{font-size:10px;color:var(--muted);display:block;margin-bottom:4px;letter-spacing:1px}
.field input{width:100%;background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:10px;padding:12px;color:var(--text);font-size:14px;outline:none}
.field-row{display:flex;gap:8px}
.field-row .field{flex:1}
.qty-inp{color:var(--gold)!important;font-size:16px!important;font-weight:800!important;text-align:center!important}
.save-btn{width:100%;padding:14px;border-radius:12px;background:linear-gradient(135deg,#f59e0b,#ef4444);border:none;color:#fff;font-size:14px;font-weight:800;cursor:pointer;margin-top:4px}
.sell-btn{width:100%;padding:14px;border-radius:12px;background:linear-gradient(135deg,#22c55e,#16a34a);border:none;color:#fff;font-size:14px;font-weight:800;cursor:pointer;margin-top:8px}
.loading{text-align:center;padding:40px;color:var(--muted);font-size:14px}
.toast{position:fixed;top:16px;left:50%;transform:translateX(-50%);background:#22c55e;color:#fff;padding:9px 22px;border-radius:26px;font-weight:600;font-size:12px;z-index:999;white-space:nowrap;box-shadow:0 4px 16px rgba(34,197,94,0.4)}
.toast.err{background:var(--red)}
</style>
</head>
<body>

